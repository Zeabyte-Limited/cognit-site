---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const why = [
  { icon: "🧩", t: "One business, one system", b: "Cognit exists because businesses were drowning in disconnected tools — a website here, stock in a spreadsheet, accounts somewhere else. We brought it all into one." },
  { icon: "😮‍💨", t: "Built from real frustration", b: "We watched good teams re-key the same order three times and lose hours stitching systems together. Cognit is the answer to that daily grind." },
  { icon: "🎯", t: "Made for distribution", b: "This isn't a generic platform bent into shape. It's shaped by years of running real ordering, stock and accounts for wholesale and distribution businesses." },
];

const different = [
  { icon: "🛒", t: "A store that's built in", b: "Cognit has a real B2B online store at its heart — not a plugin. Your customers order from a branded site that shares the same live stock and pricing." },
  { icon: "🏦", t: "Real accounting underneath", b: "A genuine general ledger sits under everything, so Cognit can run your books on its own — or sync to Xero if you'd rather keep it." },
  { icon: "⚡", t: "Fast to launch", b: "No multi-year ERP saga. We set it up, move your data and train your team, so you're running on one system in weeks, not years." },
  { icon: "🇳🇿", t: "Local support, your timezone", b: "Built and supported in New Zealand. When you call, you reach real people who understand distribution and pick up the phone." },
];

const stats = [
  { v: "10+ yrs", l: "building the software distribution businesses run on" },
  { v: "NZ & AU", l: "proven across food and wholesale distribution" },
  { v: "One system", l: "store, stock, accounts and reporting — together" },
];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Cognit System",
  alternateName: "Cognit ERP",
  url: "https://www.cognitsystem.com",
  logo: "https://www.cognitsystem.com/logo.png",
  description:
    "Cognit is an all-in-one cloud ERP with a built-in B2B online store, made by Zeabyte — a New Zealand technology company with 10+ years building the software wholesale and distribution businesses run on, proven across New Zealand and Australia.",
  email: "contact@zeabyte.co.nz",
  telephone: "+64 22 169 1376",
  foundingLocation: { "@type": "Place", name: "New Zealand" },
  parentOrganization: { "@type": "Organization", name: "Zeabyte Limited", url: "https://www.zeabyte.co.nz" },
  areaServed: ["New Zealand", "Australia"],
  slogan: "One business. One system.",
};
---

<Layout
  title="About Cognit — The All-in-One ERP Built by Zeabyte in New Zealand"
  description="Cognit is an all-in-one cloud ERP with a built-in online store, made by Zeabyte — a New Zealand company with 10+ years building the software wholesale and distribution businesses run on. Built and supported in NZ, in your timezone. Book a demo."
  path="/about"
  schema={orgSchema}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/warehouse-worker.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-4xl px-5 pb-20 pt-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">
          <span class="h-2 w-2 rounded-full bg-cog-teal"></span> About Cognit
        </span>
        <h1 class="mx-auto mt-7 max-w-3xl text-[2.6rem] font-extrabold leading-[1.04] tracking-tight text-white sm:text-6xl">
          Built by people who
          <span class="text-gradient-bright"> actually run distribution systems.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
          Cognit is made by <strong class="text-white">Zeabyte</strong>, a New Zealand
          technology company that has spent more than ten years building the software
          wholesale and distribution businesses run on. Cognit is the all-in-one ERP
          distilled from that work — built and supported in NZ, in your timezone.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn-grad">Book a demo</a>
        </div>
      </div>
    </section>

    <!-- THE WHY -->
    <section class="mx-auto max-w-5xl px-5 py-20 text-center sm:px-8">
      <h2 class="text-3xl font-extrabold leading-[1.15] tracking-tight text-cog-ink sm:text-5xl">
        One business should run on
        <span class="text-gradient"> one system.</span>
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-cog-slate">
        We didn't set out to build an ERP for the sake of it. We built Cognit because
        we kept seeing the same thing: capable businesses drowning in disconnected
        tools, re-keying the same order over and over, and never quite trusting their
        own numbers. <strong class="text-cog-ink">One business, one system</strong>
        became the whole point — so an online order updates your stock, your invoice
        and your books the moment it lands.
      </p>
    </section>

    <!-- WHY (cards) -->
    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="chip bg-cog-lilac text-cog-purple-600">Why we built it</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">From years of real distribution work.</h2>
        <p class="mt-4 text-lg text-cog-slate">Cognit is the answer to problems we watched businesses live with every day.</p>
      </div>
      <div class="mt-12 grid gap-4 lg:grid-cols-3">
        {why.map((w) => (
          <div class="card-hairline card-hover rounded-3xl p-6">
            <span class="brand-gradient flex h-10 w-10 items-center justify-center rounded-xl text-lg">{w.icon}</span>
            <h3 class="mt-4 text-lg font-bold text-cog-ink">{w.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-cog-slate">{w.b}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- WHAT MAKES IT DIFFERENT -->
    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="chip bg-cog-sky text-cog-blue-700">What makes it different</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">Not another generic platform.</h2>
        <p class="mt-4 text-lg text-cog-slate">Four things set Cognit apart from the patchwork most businesses live with.</p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {different.map((d) => (
          <div class="card-hairline card-hover rounded-3xl p-6">
            <span class="brand-gradient flex h-10 w-10 items-center justify-center rounded-xl text-lg">{d.icon}</span>
            <h3 class="mt-4 text-lg font-bold text-cog-ink">{d.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-cog-slate">{d.b}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- TRUST / STATS BAND -->
    <section class="px-4 py-10 sm:px-8">
      <div class="orbs relative mx-auto max-w-6xl overflow-hidden rounded-[2rem] bg-cog-ink px-6 py-16 text-white sm:px-12">
        <div class="dotgrid absolute inset-0 opacity-50"></div>
        <div class="relative">
          <div class="mx-auto max-w-2xl text-center">
            <span class="chip border border-white/15 text-blue-200">🇳🇿 Built and supported in New Zealand</span>
            <h2 class="mt-5 text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl">A decade of distribution, in one system.</h2>
          </div>
          <div class="mt-12 grid gap-3 sm:grid-cols-3">
            {stats.map((s) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-8 text-center backdrop-blur">
                <div class="text-4xl font-extrabold text-white sm:text-5xl">{s.v}</div>
                <div class="mt-3 text-sm leading-relaxed text-slate-300">{s.l}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
