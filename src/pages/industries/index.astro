---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Integrations from "../../components/Integrations.astro";

const industries = [
  {
    href: "/industries/food-distribution",
    icon: "🍎",
    name: "Food distribution",
    short:
      "Perishable stock, customer-specific pricing, reps on the road, supplier rebates and multiple branches — run the lot on one system with a built-in ordering store for your customers.",
    tag: "Proven in NZ food distribution",
  },
  {
    href: "/industries/wholesale-distribution",
    icon: "📦",
    name: "Wholesale distribution",
    short:
      "Accurate stock, fast purchasing and goods receipting, protected margins and a 24/7 B2B online store — with your accounts posting themselves underneath.",
    tag: "One system, every order",
  },
  {
    href: "/industries/importers",
    icon: "🚢",
    name: "Importers & distributors",
    short:
      "Landed costs, inventory across the supply chain, selling on to trade customers through your own store, rebates and claim-backs, and financials — all connected.",
    tag: "Import to sell-through, joined up",
  },
];

const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Industries Cognit ERP serves",
  itemListElement: industries.map((ind, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: ind.name,
    url: `https://cognitsystem.com${ind.href}/`,
  })),
};
---

<Layout
  title="ERP for Distributors, Wholesalers & Importers | Cognit — NZ"
  description="Cognit is the all-in-one ERP for businesses that move product — food distributors, wholesalers and importers. Built-in B2B online store, inventory, purchasing, accounting, invoicing, rebates and reporting in one system. Integrates with Xero. Book a demo."
  path="/industries"
  schema={listSchema}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/warehouse-aisle.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-4xl px-5 pt-20 pb-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">
          <span class="h-2 w-2 rounded-full bg-cog-teal"></span> Built for businesses that move product
        </span>
        <h1 class="mx-auto mt-7 max-w-3xl text-[2.6rem] font-extrabold leading-[1.05] tracking-tight text-white sm:text-6xl">
          ERP built for the businesses that
          <span class="text-gradient-bright"> move product.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
          If you take orders, hold stock and invoice trade customers, Cognit runs
          your whole operation from one login — with a built-in B2B online store so
          your customers can order 24/7.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a href="/contact" class="btn-grad">Book a demo</a>
          <a href="/platform" class="btn-ghost !border-white/30 !text-white">See the platform →</a>
        </div>
      </div>
    </section>

    <!-- INDUSTRY CARDS -->
    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div class="mb-10 max-w-2xl">
        <span class="chip bg-cog-lilac text-cog-purple-600">Industries we serve</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">
          One system, shaped to how you trade
        </h2>
        <p class="mt-4 text-lg text-cog-slate">
          Cognit is the all-in-one ERP for distributors, wholesalers and importers —
          the same connected platform, tuned to the way your industry works.
        </p>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        {industries.map((ind) => (
          <a href={ind.href} class="card-grad card-hover group flex flex-col rounded-3xl p-7">
            <div class="flex items-center gap-3">
              <span class="brand-gradient flex h-11 w-11 items-center justify-center rounded-xl text-xl">{ind.icon}</span>
              <span class="chip bg-cog-sky text-cog-blue-700">{ind.tag}</span>
            </div>
            <h3 class="mt-5 text-xl font-extrabold tracking-tight text-cog-ink">{ind.name}</h3>
            <p class="mt-3 flex-1 text-cog-slate">{ind.short}</p>
            <span class="mt-5 inline-block text-sm font-semibold text-cog-purple transition group-hover:translate-x-1">Explore {ind.name.toLowerCase()} →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- SUITS ANY ORDER-TAKING BUSINESS -->
    <section class="mx-auto max-w-6xl px-5 pb-20 sm:px-8">
      <div class="card-hairline rounded-3xl p-8 sm:p-10">
        <div class="grid items-center gap-8 lg:grid-cols-[1.1fr_0.9fr]">
          <div>
            <span class="chip bg-cog-sky text-cog-blue-700">Not on the list?</span>
            <h2 class="mt-5 text-2xl font-extrabold tracking-tight text-cog-ink sm:text-3xl">
              If you order, stock and invoice — Cognit fits.
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-cog-slate">
              Cognit suits any order-taking, stock-holding business. Whatever you sell,
              the work is the same: take the order, manage the stock, send the invoice,
              keep the books and know your numbers. Cognit does all of it on one platform,
              with a built-in online store for your customers and a two-way sync to Xero.
            </p>
            <a href="/contact" class="btn-grad mt-7">Book a demo</a>
          </div>
          <div class="grid grid-cols-2 gap-3">
            {[
              { icon: "🛒", t: "Built-in B2B store" },
              { icon: "📦", t: "Live inventory" },
              { icon: "💰", t: "One-click invoicing" },
              { icon: "📊", t: "Real accounting & GL" },
            ].map((x) => (
              <div class="rounded-2xl border border-black/5 bg-cog-stone/50 p-5">
                <div class="text-2xl">{x.icon}</div>
                <div class="mt-2 font-semibold text-cog-ink">{x.t}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- INTEGRATIONS -->
    <Integrations />
  </main>

  <Footer />
</Layout>
