---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { modules } from "../../data/modules.js";

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Cognit ERP modules",
  itemListElement: modules.map((m, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: m.name,
    description: m.short,
    url: `https://www.cognitsystem.com/features/${m.slug}/`,
  })),
};
---

<Layout
  title="Cognit Modules — Everything an All-in-One ERP Should Do"
  description="Explore every Cognit module: built-in online store, sales & pricing, inventory & warehouse, purchasing, accounting & general ledger, invoicing, rebates, reporting and CRM — all in one ERP."
  path="/features"
  schema={schema}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/warehouse-aisle.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-4xl px-5 pt-20 pb-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">
          <span class="h-2 w-2 rounded-full bg-cog-teal"></span> Modules
        </span>
        <h1 class="mt-7 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">Every module. <span class="text-gradient-bright">One system.</span></h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">
          Cognit isn't a starter app you outgrow. It's a complete ERP — every
          module below is fully built and ready to switch on as you grow.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div class="grid gap-4 md:grid-cols-2">
        {modules.map((m) => (
          <a href={`/features/${m.slug}`} class="card-hairline card-hover group flex gap-5 rounded-3xl p-6">
            <span class="brand-gradient flex h-10 w-10 flex-none items-center justify-center rounded-xl text-lg">{m.icon}</span>
            <div>
              <h2 class="text-lg font-bold text-cog-ink">{m.name}</h2>
              <p class="mt-1.5 text-sm leading-relaxed text-cog-slate">{m.short}</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-500">{m.blurb}</p>
              <span class="mt-3 inline-block text-sm font-semibold text-cog-purple opacity-0 transition group-hover:opacity-100">Learn more →</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
