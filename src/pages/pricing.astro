---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const plans = [
  {
    name: "Free trial",
    slug: "trial",
    price: "0",
    unit: "for 7 days",
    tagline: "Try the whole system — every feature unlocked — free for 7 days.",
    cta: "Start free trial",
    href: "/start?plan=trial",
    popular: false,
    features: [
      "Everything unlocked for 7 days",
      "The full ERP + built-in online store",
      "Loaded with your data, set up for you",
      "No credit card to start",
      "Choose a plan when you're ready",
    ],
    footnote: "When you're ready, pick the plan that fits — Standard, Premium or Enterprise.",
  },
  {
    name: "Standard",
    slug: "standard",
    price: "599",
    unit: "NZD / month",
    tagline: "A B2B online store with your products and customers — take orders online.",
    cta: "Start free trial",
    href: "/start?plan=standard",
    popular: false,
    features: [
      "Built-in B2B online store",
      "Your product catalogue",
      "Your customer accounts",
      "Online order management & history",
      "Multiple users",
      "NZ-based support",
    ],
    footnote: "Inventory, purchasing, accounting and the rest are on Premium.",
  },
  {
    name: "Premium",
    slug: "premium",
    price: "1,699",
    unit: "NZD / month",
    tagline: "The complete ERP — run your whole operation in one system.",
    cta: "Start free trial",
    href: "/start?plan=premium",
    popular: true,
    features: [
      "Everything in Standard, plus:",
      "Inventory & warehouse management",
      "Purchasing, goods receipting & supplier bills",
      "Accounting & general ledger",
      "Invoicing, statements & customer pricing",
      "Supplier rebates & claim-backs",
      "Quotes, pick sheets & missed opportunities",
      "Xero integration",
      "Advanced reporting & P&L",
    ],
  },
  {
    name: "Enterprise",
    slug: "enterprise",
    price: "Let's talk",
    custom: true,
    unit: "custom pricing",
    tagline: "For multi-branch operations that want AI, intelligence and a bespoke fit.",
    cta: "Talk to our team",
    href: "/contact",
    popular: false,
    features: [
      "Everything in Premium, plus:",
      "API access & data export",
      "One-click Backup & Restore",
      "AI invoice processing — reads supplier invoices & books stock in",
      "Rep intelligence / Customer 360",
      "Multi-branch & multi-location",
      "Per-user granular permissions",
      "Dedicated infrastructure & SLA",
      "White-glove onboarding & a dedicated account manager",
    ],
  },
];

// 'free' column = the 7-day Trial (everything unlocked). 's' = Standard (online
// store + products + customers only). 'p' = Premium (full ERP). Enterprise adds
// AI invoice processing, rep intelligence, multi-branch & permissions on top.
const compare = [
  { f: "Built-in B2B online store", free: true, s: true, p: true },
  { f: "Online order management", free: true, s: true, p: true },
  { f: "Order history", free: true, s: true, p: true },
  { f: "Product catalogue", free: "Unlimited", s: "Unlimited", p: "Unlimited" },
  { f: "Customer accounts", free: "Unlimited", s: "Unlimited", p: "Unlimited" },
  { f: "User logins", free: "Multiple", s: "Multiple", p: "Multiple" },
  { f: "Inventory & warehouse", free: true, s: false, p: true },
  { f: "Purchasing, goods receipts & supplier bills", free: true, s: false, p: true },
  { f: "Invoicing, statements & customer pricing", free: true, s: false, p: true },
  { f: "Accounting & general ledger", free: true, s: false, p: true },
  { f: "Supplier rebates & claim-backs", free: true, s: false, p: true },
  { f: "Quotes & pick sheets", free: true, s: false, p: true },
  { f: "Advanced reporting & P&L", free: true, s: false, p: true },
  { f: "Xero integration", free: true, s: false, p: true },
  { f: "One-click Backup & Restore", free: true, s: false, p: "Enterprise" },
  { f: "AI invoice processing", free: true, s: false, p: "Enterprise" },
  { f: "Rep intelligence / Customer 360", free: true, s: false, p: "Enterprise" },
  { f: "Multi-branch & multi-location", free: true, s: false, p: "Enterprise" },
  { f: "Per-user granular permissions", free: true, s: false, p: "Enterprise" },
  { f: "Support", free: "Full", s: "NZ-based", p: "Priority" },
];

const faqs = [
  {
    q: "How does the free trial work?",
    a: "You start with a 7-day free trial of the whole system — every feature unlocked, loaded with data and set up for you, no credit card. At the end of the 7 days you pick the plan that fits: Standard for a B2B online store with your products and customers, Premium for the full ERP, or Enterprise for AI, multi-branch and more.",
  },
  {
    q: "What happens after the 7 days?",
    a: "On Standard or Premium you get the full system free for 7 days. Near the end of your trial we'll check in. If Cognit is working for you, you continue on your chosen plan; if it isn't the right fit, you simply stop — there's no lock-in and nothing to cancel if you never started paying.",
  },
  {
    q: "Do I need a credit card?",
    a: "No. You can start your 7-day free trial without entering any card details. We set Cognit up for you and email your login — you only arrange payment if you decide to continue on a paid plan after the trial.",
  },
  {
    q: "Can I change plans?",
    a: "Any time. Start Standard for a B2B online store with your products and customers, step up to Premium for the full ERP (inventory, purchasing, accounting, invoicing, rebates, reporting), and to Enterprise for AI invoice processing, rep intelligence, multi-branch and per-user permissions. Every module is already built into Cognit, so changing plan is a setting we switch on — not another project. You can move down again too. No lock-in, cancel anytime.",
  },
  {
    q: "Is my data mine?",
    a: "Always. Your customers, products, orders, invoices and accounts are yours. You can export your records to Excel or PDF whenever you like, and if you ever leave, you take your data with you. On paid plans your data can also run on your own server.",
  },
];

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Cognit ERP",
  description:
    "Cognit is an all-in-one cloud ERP with a built-in B2B e-commerce online store. Start free, or try Standard or Premium free for 7 days — sales, inventory, purchasing, accounting, invoicing, rebates and reporting in one system.",
  brand: { "@type": "Brand", name: "Cognit" },
  offers: [
    {
      "@type": "Offer",
      name: "Free trial",
      price: "0",
      priceCurrency: "NZD",
      description: "A 7-day free trial of the entire system — every feature unlocked, no credit card. After 7 days, choose Standard, Premium or Enterprise to continue.",
      availability: "https://schema.org/InStock",
      url: "https://cognitsystem.com/pricing/",
    },
    {
      "@type": "Offer",
      name: "Standard",
      price: "599",
      priceCurrency: "NZD",
      description: "Per month, after a 7-day free trial. A B2B online store with your products and customers — online order management & history, multiple users, NZ-based support. Inventory, purchasing and accounting are on Premium.",
      availability: "https://schema.org/InStock",
      url: "https://cognitsystem.com/pricing/",
    },
    {
      "@type": "Offer",
      name: "Premium",
      price: "1699",
      priceCurrency: "NZD",
      description: "Per month, with a 7-day free trial. Everything in Standard plus accounting & general ledger, supplier rebates & claim-backs, advanced reporting & P&L, Xero & other integrations, API access, AI reorder suggestions, priority support and guided onboarding.",
      availability: "https://schema.org/InStock",
      url: "https://cognitsystem.com/pricing/",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title="Cognit Pricing — 7-Day Free Trial, then Standard, Premium & Enterprise"
  description="Cognit pricing: a 7-day free trial of the whole system, plus paid plans Standard (NZD $599/mo) and Premium (NZD $1,699/mo) — each with a 7-day free trial, no credit card. No lock-in. Setup, data migration and training included on paid plans."
  path="/pricing"
  schema={[offerSchema, faqSchema]}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/hero-cranes-night.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-5xl px-5 pb-20 pt-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">
          <span class="h-2 w-2 rounded-full bg-cog-teal"></span> Start free · upgrade when you're ready
        </span>
        <h1 class="mx-auto mt-7 max-w-4xl text-[2.6rem] font-extrabold leading-[1.05] tracking-tight text-white sm:text-6xl">
          Start free. Grow into
          <span class="text-gradient-bright"> the whole system.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
          Get your own built-in B2B online store free, forever — or try the full
          Standard or Premium system free for 7 days, no credit card. We set it up
          for you and email your login.
        </p>
      </div>
    </section>

    <!-- 14-DAY TRIAL BANNER -->
    <section class="mx-auto -mt-10 max-w-5xl px-5 sm:px-8">
      <div class="card-grad relative z-10 flex flex-col items-center justify-between gap-4 rounded-2xl px-6 py-5 text-center shadow-xl shadow-cog-purple/15 sm:flex-row sm:text-left">
        <p class="text-cog-ink">
          <strong class="font-extrabold">Try Standard or Premium free for 7 days</strong>
          — no credit card. We set it up for you and email your login.
        </p>
        <a href="/start?plan=standard" class="btn-grad !px-6 !py-3 text-sm">Start 7-day free trial →</a>
      </div>
    </section>

    <!-- PLAN CARDS -->
    <section class="mx-auto max-w-6xl px-5 pb-12 pt-16 sm:px-8">
      <div class="grid items-start gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {plans.map((plan) => (
          <div class={"card-hover relative flex flex-col rounded-3xl p-8 " + (plan.popular ? "card-grad shadow-xl shadow-cog-purple/15 lg:-mt-4 lg:pb-10" : "card-hairline")}>
            {plan.popular && (
              <span class="brand-gradient absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-white shadow-lg shadow-cog-purple/30">
                Most popular
              </span>
            )}
            <h2 class="text-xl font-extrabold tracking-tight text-cog-ink">{plan.name}</h2>
            <p class="mt-2 min-h-[3.5rem] text-sm leading-relaxed text-cog-slate">{plan.tagline}</p>
            <div class="mt-5 flex items-end gap-1.5">
              {plan.custom ? (
                <span class="text-4xl font-extrabold tracking-tight text-cog-ink">{plan.price}</span>
              ) : (
                <span class="text-5xl font-extrabold tracking-tight text-cog-ink">${plan.price}</span>
              )}
              <span class="mb-1.5 text-sm font-medium text-slate-500">{plan.unit}</span>
            </div>
            {plan.trial && (
              <p class="mt-2 text-sm font-semibold text-cog-teal-600">{plan.trial}</p>
            )}
            <a href={plan.href} class={"mt-6 " + (plan.popular ? "btn-grad" : "btn-ghost")}>
              {plan.cta}
            </a>
            <ul class="mt-7 space-y-3 text-sm text-cog-slate">
              {plan.features.map((f, i) => (
                <li class={"flex gap-3 " + (i === 0 && f.includes("Everything in") ? "font-semibold text-cog-ink" : "")}>
                  <span class="mt-0.5 flex-none text-cog-teal">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            {plan.footnote && (
              <p class="mt-6 border-t border-black/5 pt-4 text-xs leading-relaxed text-slate-400">{plan.footnote}</p>
            )}
          </div>
        ))}
      </div>

      <p class="mt-10 text-center text-sm font-medium text-slate-500">
        No lock-in. Cancel anytime. Setup, data migration &amp; training included on paid plans.
      </p>
    </section>

    <!-- COMPARE TABLE -->
    <section class="mx-auto max-w-5xl px-5 py-24 sm:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="chip bg-cog-sky text-cog-blue-700">Compare plans</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">What's in each plan</h2>
        <p class="mt-4 text-lg text-cog-slate">Start with a free online store, then switch on inventory, accounting and the advanced modules as you grow.</p>
      </div>

      <div class="card-hairline overflow-hidden rounded-3xl">
        <div class="grid grid-cols-[1.6fr_0.8fr_0.8fr_0.8fr] bg-cog-ink text-white">
          <div class="px-4 py-4 text-sm font-bold sm:px-7">Feature</div>
          <div class="px-2 py-4 text-center text-sm font-bold text-slate-200">Trial</div>
          <div class="px-2 py-4 text-center text-sm font-bold text-cog-teal">Standard</div>
          <div class="px-2 py-4 text-center text-sm font-bold text-slate-200">Premium</div>
        </div>
        {compare.map((row, i) => (
          <div class={"grid grid-cols-[1.6fr_0.8fr_0.8fr_0.8fr] " + (i % 2 === 0 ? "bg-white" : "bg-cog-stone")}>
            <div class="px-4 py-4 text-sm font-medium text-cog-ink sm:px-7">{row.f}</div>
            <div class="px-2 py-4 text-center text-sm">
              {row.free === true ? <span class="font-bold text-cog-teal">✓</span>
                : row.free === false ? <span class="text-slate-300">—</span>
                : <span class="text-xs font-medium text-cog-slate">{row.free}</span>}
            </div>
            <div class="px-2 py-4 text-center text-sm">
              {row.s === true ? <span class="font-bold text-cog-teal">✓</span>
                : row.s === false ? <span class="text-slate-300">—</span>
                : <span class="text-xs font-medium text-cog-slate">{row.s}</span>}
            </div>
            <div class="px-2 py-4 text-center text-sm">
              {row.p === true ? <span class="font-bold text-cog-teal">✓</span>
                : row.p === false ? <span class="text-slate-300">—</span>
                : <span class="text-xs font-medium text-cog-slate">{row.p}</span>}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href="/start?plan=free" class="btn-ghost">Get started free</a>
        <a href="/start?plan=standard" class="btn-grad">Start 7-day free trial →</a>
      </div>
    </section>

    <!-- VALUE BAND -->
    <section class="px-4 py-10 sm:px-8">
      <div class="orbs relative mx-auto max-w-6xl overflow-hidden rounded-[2rem] bg-cog-ink px-6 py-16 text-center text-white sm:px-12">
        <div class="dotgrid absolute inset-0 opacity-50"></div>
        <div class="relative">
          <h2 class="mx-auto max-w-2xl text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl">
            One subscription replaces a <span class="text-gradient-bright">shelf full of tools.</span>
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">
            Think about what you pay today for a website, an ordering plugin, an inventory
            tool, accounting software, a reporting add-on — plus the time lost re-keying
            between them. Cognit is one price for all of it, working as a single system.
          </p>
          <div class="mt-10 grid gap-3 sm:grid-cols-4">
            {[
              { t: "Online store", e: "🛒" },
              { t: "Inventory & purchasing", e: "📦" },
              { t: "Accounting & ledger", e: "📊" },
              { t: "Reporting & insights", e: "📈" },
            ].map((x) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
                <div class="text-2xl">{x.e}</div>
                <div class="mt-2 text-sm font-semibold text-white">{x.t}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-3xl px-5 py-24 sm:px-8">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">Pricing questions, answered</h2>
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="card-hairline group rounded-2xl p-6 open:shadow-md">
            <summary class="flex cursor-pointer list-none items-center justify-between text-lg font-bold text-cog-ink">
              {f.q}
              <span class="ml-4 text-cog-purple transition group-open:rotate-45">＋</span>
            </summary>
            <p class="mt-3 leading-relaxed text-cog-slate">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
