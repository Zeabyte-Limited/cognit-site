---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const plans = [
  {
    name: "Standard",
    price: "499",
    tagline: "The all-in-one ERP with a built-in online store.",
    cta: "Book a demo",
    popular: false,
    features: [
      "Built-in B2B e-commerce online store",
      "Sales orders & customer-specific pricing",
      "Inventory & warehouse management",
      "Purchasing & goods receipting",
      "Invoicing, credit notes & accounts receivable",
      "Accounting & real general ledger",
      "Core business reporting & P&L",
      "Two-way Xero sync",
      "New Zealand based support",
    ],
  },
  {
    name: "Premium",
    price: "1,400",
    tagline: "Everything in Standard, plus the advanced modules and white-glove care.",
    cta: "Talk to us",
    popular: true,
    features: [
      "Everything in Standard",
      "Supplier rebates & claim-backs",
      "Advanced reporting & insights",
      "Tablet stocktakes & AI reorder suggestions",
      "Deeper integrations to your other systems",
      "Priority support",
      "Guided onboarding & data migration",
      "Hands-on team training",
    ],
  },
];

const compare = [
  { f: "Built-in B2B online store", s: true, p: true },
  { f: "Sales, inventory, purchasing & invoicing", s: true, p: true },
  { f: "Accounting & general ledger", s: true, p: true },
  { f: "Two-way Xero sync", s: true, p: true },
  { f: "Core reporting & P&L", s: true, p: true },
  { f: "NZ-based support", s: true, p: true },
  { f: "Supplier rebates & claim-backs", s: false, p: true },
  { f: "Advanced reporting & insights", s: false, p: true },
  { f: "Tablet stocktakes & AI reorder suggestions", s: false, p: true },
  { f: "Deeper integrations to your other systems", s: false, p: true },
  { f: "Priority support", s: false, p: true },
  { f: "Guided onboarding, data migration & training", s: false, p: true },
];

const faqs = [
  {
    q: "Is there a setup fee?",
    a: "No surprise setup fees. Your plan includes setup and training — we move your data across, configure Cognit for how your business works and train your team, then support you once you're live. Book a demo and we'll give you a clear picture of timeline and cost for your business.",
  },
  {
    q: "Can I add modules later?",
    a: "Yes. Every module is already built into Cognit, so adding one is a setting, not another integration project. Most businesses start on Standard with the online store, sales, inventory, invoicing and accounting, then move to Premium when they want rebates, advanced reporting and the extras. You're never locked out of a feature — you simply turn it on.",
  },
  {
    q: "Do I need separate accounting software?",
    a: "No. Cognit has a real general ledger underneath everything — chart of accounts, journals, trial balance and balance sheet, with automatic posting — so it can run your accounts on its own and replace separate accounting software. If you'd rather keep your accounting system, Cognit syncs two-way with Xero, so you can do that too.",
  },
  {
    q: "Is my data mine?",
    a: "Always. Your business data is yours — your customers, products, orders, invoices and accounts. You can export your reports and records to Excel or PDF at any time, and if you ever leave, you take your data with you.",
  },
  {
    q: "Are there per-user licence fees?",
    a: "No. Cognit is one flat monthly price — no per-seat games and no charging you more every time your team grows. Add as many users as your business needs.",
  },
];

const offerSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Cognit ERP",
  description:
    "Cognit is an all-in-one cloud ERP with a built-in B2B e-commerce online store — sales, inventory, purchasing, accounting, invoicing, rebates and reporting in one system.",
  brand: { "@type": "Brand", name: "Cognit" },
  offers: [
    {
      "@type": "Offer",
      name: "Standard",
      price: "499",
      priceCurrency: "NZD",
      description: "Per month. All-in-one ERP with built-in online store, core modules, Xero sync and NZ support. No per-user licences.",
      availability: "https://schema.org/InStock",
      url: "https://www.cognitsystem.com/pricing/",
    },
    {
      "@type": "Offer",
      name: "Premium",
      price: "1400",
      priceCurrency: "NZD",
      description: "Per month. Everything in Standard plus rebates & claim-backs, advanced reporting, deeper integrations, priority support and guided onboarding.",
      availability: "https://schema.org/InStock",
      url: "https://www.cognitsystem.com/pricing/",
    },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title="Cognit Pricing — All-in-One ERP & Online Store From $499/mo NZD"
  description="Simple Cognit pricing: Standard NZD $499/month for the all-in-one ERP with built-in online store, or Premium NZD $1,400/month with advanced modules, deeper integrations and priority support. One price, all modules, no per-user licences. Book a demo."
  path="/pricing"
  schema={[offerSchema, faqSchema]}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/hero-cranes-night.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-5xl px-5 pb-20 pt-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">
          <span class="h-2 w-2 rounded-full bg-cog-teal"></span> Simple, honest pricing
        </span>
        <h1 class="mx-auto mt-7 max-w-4xl text-[2.6rem] font-extrabold leading-[1.05] tracking-tight text-white sm:text-6xl">
          One price. Every module.
          <span class="text-gradient-bright"> No per-seat games.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
          Run your whole business — including the built-in online store — from a single
          flat monthly price. No per-user licences, no nasty surprises, setup and
          training included.
        </p>
      </div>
    </section>

    <!-- PLAN CARDS -->
    <section class="mx-auto max-w-5xl px-5 pb-20 sm:px-8">
      <div class="grid gap-5 lg:grid-cols-2">
        {plans.map((plan) => (
          <div class={"card-hover relative flex flex-col rounded-3xl p-8 sm:p-9 " + (plan.popular ? "card-grad" : "card-hairline")}>
            {plan.popular && (
              <span class="brand-gradient absolute -top-3.5 left-1/2 -translate-x-1/2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-white shadow-lg shadow-cog-purple/30">
                Most popular
              </span>
            )}
            <h2 class="text-xl font-extrabold tracking-tight text-cog-ink">{plan.name}</h2>
            <p class="mt-2 text-sm leading-relaxed text-cog-slate">{plan.tagline}</p>
            <div class="mt-6 flex items-end gap-1.5">
              <span class="text-5xl font-extrabold tracking-tight text-cog-ink">${plan.price}</span>
              <span class="mb-1.5 text-sm font-medium text-slate-500">NZD / month</span>
            </div>
            <a href="/contact" class={"mt-7 " + (plan.popular ? "btn-grad" : "btn-ghost")}>
              {plan.cta}
            </a>
            <ul class="mt-8 space-y-3 text-sm text-cog-slate">
              {plan.features.map((f) => (
                <li class="flex gap-3">
                  <span class="mt-0.5 flex-none text-cog-teal">✓</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <p class="mt-10 text-center text-sm font-medium text-slate-500">
        No per-user licences. Cancel anytime. Setup &amp; training included.
      </p>
    </section>

    <!-- COMPARE TABLE -->
    <section class="mx-auto max-w-5xl px-5 py-24 sm:px-8">
      <div class="mb-12 max-w-2xl">
        <span class="chip bg-cog-sky text-cog-blue-700">Compare plans</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">What's in each plan</h2>
        <p class="mt-4 text-lg text-cog-slate">Both run your whole business. Premium adds the advanced modules and white-glove care.</p>
      </div>

      <div class="card-hairline overflow-hidden rounded-3xl">
        <div class="grid grid-cols-[1.6fr_1fr_1fr] bg-cog-ink text-white">
          <div class="px-5 py-4 text-sm font-bold sm:px-7">Feature</div>
          <div class="px-3 py-4 text-center text-sm font-bold text-slate-200">Standard</div>
          <div class="px-3 py-4 text-center text-sm font-bold text-cog-teal">Premium</div>
        </div>
        {compare.map((row, i) => (
          <div class={"grid grid-cols-[1.6fr_1fr_1fr] " + (i % 2 === 0 ? "bg-white" : "bg-cog-stone")}>
            <div class="px-5 py-4 text-sm font-medium text-cog-ink sm:px-7">{row.f}</div>
            <div class="px-3 py-4 text-center text-sm">
              {row.s ? <span class="font-bold text-cog-teal">✓</span> : <span class="text-slate-300">—</span>}
            </div>
            <div class="px-3 py-4 text-center text-sm">
              {row.p ? <span class="font-bold text-cog-teal">✓</span> : <span class="text-slate-300">—</span>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- VALUE BAND -->
    <section class="px-4 py-10 sm:px-8">
      <div class="orbs relative mx-auto max-w-6xl overflow-hidden rounded-[2rem] bg-cog-ink px-6 py-16 text-center text-white sm:px-12">
        <div class="dotgrid absolute inset-0 opacity-50"></div>
        <div class="relative">
          <h2 class="mx-auto max-w-2xl text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl">
            One subscription replaces a <span class="text-gradient-bright">shelf full of tools.</span>
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">
            Think about what you pay today for a website, an ordering plugin, an inventory
            tool, accounting software, a reporting add-on — plus the time lost re-keying
            between them. Cognit is one price for all of it, working as a single system.
          </p>
          <div class="mt-10 grid gap-3 sm:grid-cols-4">
            {[
              { t: "Online store", e: "🛒" },
              { t: "Inventory & purchasing", e: "📦" },
              { t: "Accounting & ledger", e: "📊" },
              { t: "Reporting & insights", e: "📈" },
            ].map((x) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
                <div class="text-2xl">{x.e}</div>
                <div class="mt-2 text-sm font-semibold text-white">{x.t}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-3xl px-5 py-24 sm:px-8">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">Pricing questions, answered</h2>
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="card-hairline group rounded-2xl p-6 open:shadow-md">
            <summary class="flex cursor-pointer list-none items-center justify-between text-lg font-bold text-cog-ink">
              {f.q}
              <span class="ml-4 text-cog-purple transition group-open:rotate-45">＋</span>
            </summary>
            <p class="mt-3 leading-relaxed text-cog-slate">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
