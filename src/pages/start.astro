---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const planChips = [
  { slug: "free", name: "Free", sub: "$0 forever" },
  { slug: "standard", name: "Standard", sub: "$899/mo · 14-day trial" },
  { slug: "premium", name: "Premium", sub: "$1,999/mo · 14-day trial" },
];

const benefits = [
  { e: "⚡", t: "Live in days", s: "We set Cognit up for you and email your login." },
  { e: "💳", t: "No credit card", s: "Try Standard or Premium free for 14 days." },
  { e: "🇳🇿", t: "NZ-based support", s: "Real people who know food & wholesale." },
  { e: "🔒", t: "Your data is yours", s: "Export anytime. Runs on your own server on paid plans." },
];

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Start your 14-day free trial of Cognit",
  description:
    "Start with Cognit free — your own built-in B2B online store, or a 14-day free trial of the full Standard or Premium system. No credit card. We set it up for you and email your login.",
  url: "https://cognitsystem.com/start/",
  isPartOf: { "@id": "https://cognitsystem.com/#website" },
  about: { "@id": "https://cognitsystem.com/#software" },
};
---

<Layout
  title="Start Free — Get Started With Cognit (14-Day Free Trial)"
  description="Start your 14-day free trial of Cognit — no credit card. Get your own built-in B2B online store free, or try the full Standard or Premium system. We set it up for you and email your login. No lock-in, NZ-based support."
  path="/start"
  schema={webPageSchema}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO + SIGNUP -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/hero-warehouse-dark.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>

      <div class="mx-auto grid max-w-6xl gap-12 px-5 py-20 sm:px-8 lg:grid-cols-2 lg:py-28">
        <!-- LEFT: pitch + trust -->
        <div class="hero-rise">
          <span class="chip border border-white/15 text-slate-200">
            <span class="h-2 w-2 rounded-full bg-cog-teal"></span> 14-day free trial · no credit card
          </span>
          <h1 class="mt-7 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
            Start your <span class="text-gradient-bright">14-day free trial.</span>
          </h1>
          <p class="mt-5 max-w-md text-lg leading-relaxed text-slate-300">
            Tell us a little about your business and we'll set Cognit up for you —
            then email your login. Try Standard or Premium free for 14 days, no card,
            or start on the free plan and grow from there.
          </p>

          <div class="mt-9 grid gap-3 sm:grid-cols-2">
            {benefits.map((b) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-5 backdrop-blur">
                <div class="text-2xl">{b.e}</div>
                <div class="mt-2 font-semibold text-white">{b.t}</div>
                <div class="mt-1 text-sm leading-relaxed text-slate-300">{b.s}</div>
              </div>
            ))}
          </div>

          <div class="mt-9 rounded-2xl border border-white/15 bg-white/10 p-6 backdrop-blur">
            <p class="text-sm text-slate-300">Prefer a guided walkthrough first?</p>
            <a href="/contact" class="mt-1 block text-lg font-bold text-white hover:text-cog-teal">Book a 30-minute demo →</a>
            <a href="tel:+64221691376" class="text-sm font-medium text-slate-200 hover:underline">or call +64 22 169 1376</a>
          </div>
        </div>

        <!-- RIGHT: signup form -->
        <div class="card-grad rounded-3xl p-7 sm:p-9">
          <form id="start-form" action="/api/lead" method="POST" class="space-y-5">
            <input type="hidden" name="source" value="cognitsystem.com/start" />
            <input type="hidden" id="plan" name="plan" value="standard" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <!-- PLAN PICKER -->
            <div>
              <span class="block text-sm font-semibold text-cog-ink">Choose your plan</span>
              <div id="plan-chips" class="mt-2 grid grid-cols-3 gap-2">
                {planChips.map((c) => (
                  <button
                    type="button"
                    data-plan={c.slug}
                    class="plan-chip rounded-xl border border-slate-300 bg-white px-2 py-3 text-center transition hover:border-cog-blue"
                  >
                    <span class="block text-sm font-bold text-cog-ink">{c.name}</span>
                    <span class="mt-0.5 block text-[11px] font-medium text-slate-500">{c.sub}</span>
                  </button>
                ))}
              </div>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <div>
                <label class="block text-sm font-semibold text-cog-ink" for="name">Full name</label>
                <input id="name" name="name" required class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-cog-ink outline-none transition focus:border-cog-blue focus:ring-2 focus:ring-blue-100" placeholder="Jane Smith" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-cog-ink" for="company">Company</label>
                <input id="company" name="company" required class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-cog-ink outline-none transition focus:border-cog-blue focus:ring-2 focus:ring-blue-100" placeholder="Your company" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-cog-ink" for="email">Work email</label>
                <input id="email" type="email" name="email" required class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-cog-ink outline-none transition focus:border-cog-blue focus:ring-2 focus:ring-blue-100" placeholder="jane@company.co.nz" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-cog-ink" for="phone">Phone</label>
                <input id="phone" name="phone" class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-cog-ink outline-none transition focus:border-cog-blue focus:ring-2 focus:ring-blue-100" placeholder="+64 …" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-cog-ink" for="message">What do you sell? <span class="font-normal text-slate-400">(optional)</span></label>
              <input id="message" name="message" class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-cog-ink outline-none transition focus:border-cog-blue focus:ring-2 focus:ring-blue-100" placeholder="e.g. food wholesale, butchery, beverages…" />
            </div>

            <button type="submit" class="btn-grad w-full !py-4 text-base">
              Start free →
            </button>
            <p class="text-center text-xs text-slate-400">No lock-in. Cancel anytime. Setup, data migration &amp; training included on paid plans.</p>

            <div id="start-success" class="hidden rounded-xl border border-green-200 bg-green-50 p-5 text-center text-sm font-medium text-green-800">
              🎉 You're in — we're setting up your Cognit now and will email your login details within one business day.
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
    (function () {
      const form = document.getElementById("start-form");
      const planInput = document.getElementById("plan");
      const chips = Array.from(document.querySelectorAll(".plan-chip"));
      const onClasses = ["border-cog-blue", "ring-2", "ring-blue-100", "bg-cog-sky"];

      function select(slug) {
        if (!chips.some((c) => c.dataset.plan === slug)) slug = "standard";
        planInput.value = slug;
        chips.forEach((c) => {
          const on = c.dataset.plan === slug;
          onClasses.forEach((cl) => c.classList.toggle(cl, on));
        });
        const btn = form.querySelector('button[type="submit"]');
        if (btn) btn.textContent = slug === "free" ? "Get started free →" : "Start 14-day free trial →";
      }

      // Preselect from ?plan= query param.
      const params = new URLSearchParams(window.location.search);
      select((params.get("plan") || "standard").toLowerCase());

      chips.forEach((c) => c.addEventListener("click", () => select(c.dataset.plan)));

      // Submit — mirrors LeadForm: POST JSON, mailto fallback.
      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const success = document.getElementById("start-success");
        const data = new FormData(form);
        let sent = false;
        const payload = Object.fromEntries(data.entries());
        // Record the signup in Cognit Control (fire-and-forget; emails the owner with the plan).
        try {
          fetch("https://api.cognitsystem.co.nz/api/control/ingest/signup", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              name: payload.name, email: payload.email, company: payload.company,
              phone: payload.phone, plan: payload.plan || "trial", source: "trial-signup",
              message: payload.message || "",
            }),
          }).catch(() => {});
        } catch (err) { /* never block the form */ }
        try {
          const res = await fetch(form.action, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          if (res.ok) sent = true;
        } catch (err) { /* fall through to mailto */ }
        if (!sent) {
          const subject = encodeURIComponent(
            "Cognit free trial signup (" + (data.get("plan") || "") + ") — " + (data.get("company") || "website signup")
          );
          const body = encodeURIComponent(
            "Plan: " + (data.get("plan") || "") +
            "\nName: " + (data.get("name") || "") +
            "\nCompany: " + (data.get("company") || "") +
            "\nEmail: " + (data.get("email") || "") +
            "\nPhone: " + (data.get("phone") || "") +
            "\nWhat they sell: " + (data.get("message") || "")
          );
          window.location.href = "mailto:contact@zeabyte.co.nz?subject=" + subject + "&body=" + body;
          if (success) success.textContent = "📧 Your email app should open with your signup ready to send. If it didn't, email us at contact@zeabyte.co.nz or call +64 22 169 1376.";
        }
        form.querySelectorAll("input,select,textarea,button").forEach((el) => (el.style.display = "none"));
        success?.classList.remove("hidden");
      });
    })();
  </script>
</Layout>
