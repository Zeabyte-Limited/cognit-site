---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const site = "https://cognitsystem.com";

const posts = [
  {
    title: "Free B2B ordering software for wholesalers",
    dek: "Put your trade customers online for $0 a month — what a free B2B ordering portal is, why distributors start free, and exactly what Cognit's Free plan includes.",
    slug: "free-b2b-ordering-software-nz",
    tag: "Free plan",
  },
  {
    title: "Why you should try an ERP before you buy",
    dek: "Most ERPs won't let you trial them — and that's a risk. What a real free trial should let you do, and how Cognit's Free plan and 14-day trials de-risk the switch.",
    slug: "erp-free-trial-nz",
    tag: "Free trial",
  },
  {
    title: "How to take wholesale orders online — for free",
    dek: "A practical, do-it-this-week guide to getting trade customers ordering online at no cost — catalogue, logins, pricing, go live — then grow into the full ERP.",
    slug: "take-wholesale-orders-online-free",
    tag: "How-to",
  },
  {
    title: "What is an all-in-one ERP with a built-in online store?",
    dek: "The concept explained — and why a store built into your ERP beats bolting a website onto separate systems.",
    slug: "all-in-one-erp-with-built-in-online-store",
    tag: "Guide",
  },
  {
    title: "The best ERP for wholesale distributors in New Zealand",
    dek: "A buyer's guide to what distributors actually need — stock, customer pricing, B2B ordering, rebates and Xero — and how to choose.",
    slug: "best-erp-for-wholesale-distributors-nz",
    tag: "Buyer's guide",
  },
  {
    title: "ERP with built-in e-commerce vs a website plus separate accounting",
    dek: "Two ways to run a product business compared — and the hidden costs and sync problems of the bolt-on approach.",
    slug: "erp-with-ecommerce-vs-website-plus-accounting",
    tag: "Comparison",
  },
  {
    title: "Do I still need Xero if I have an ERP?",
    dek: "Cognit has a real general ledger of its own and also syncs two-way with Xero. Here's when each option makes sense.",
    slug: "do-i-still-need-xero-with-an-erp",
    tag: "Accounting",
  },
  {
    title: "How to stop losing money on supplier rebates and claim-backs",
    dek: "Why spreadsheets quietly cost distributors thousands a month — and how automated rebate tracking recovers it.",
    slug: "supplier-rebates-and-claim-backs-software",
    tag: "Rebates",
  },
  {
    title: "How to replace multiple disconnected business systems with one ERP",
    dek: "The patchwork problem, a sensible migration approach, and exactly what to consolidate first.",
    slug: "replace-multiple-business-systems-with-one-erp",
    tag: "Migration",
  },
  {
    title: "Inventory and stock control software for wholesalers",
    dek: "Why disconnected stock systems quietly cost distributors money — and what real-time inventory should actually look like.",
    slug: "inventory-stock-control-software-for-wholesalers",
    tag: "Inventory",
  },
  {
    title: "MYOB or an all-in-one ERP? What Australian wholesalers need to know",
    dek: "MYOB is solid at the books, but it wasn't built for B2B ordering, live stock or wholesale pricing. How to tell if it's still enough — and how Cognit fits either way.",
    slug: "myob-vs-all-in-one-erp-for-wholesalers",
    tag: "Accounting",
  },
  {
    title: "ERP for food and beverage distributors: what to look for",
    dek: "Short shelf life, tight margins and customers ordering at all hours. What an ERP actually needs to handle food and beverage distribution — and where generic software falls short.",
    slug: "erp-for-food-and-beverage-distributors",
    tag: "Food & beverage",
  },
  {
    title: "Landed cost software for importers and distributors",
    dek: "If you're pricing off the supplier invoice, you're pricing wrong. What freight, duty and exchange rate actually do to your unit cost — and how to stop losing margin to it.",
    slug: "landed-cost-software-for-importers",
    tag: "Importing",
  },
  {
    title: "Customer-specific pricing for wholesale distributors",
    dek: "Your best customers get a better price. If it only lives in a rep's head or a spreadsheet, you're one order away from getting it wrong — how customer pricing and price lists should actually work.",
    slug: "customer-specific-pricing-for-wholesalers",
    tag: "Pricing",
  },
  {
    title: "Credit limits and accounts receivable for wholesale distributors",
    dek: "Trade credit is normal — bad debt from ignoring credit limits isn't. How to enforce credit limits and trade terms automatically, on every order, without a rep having to be the bad guy.",
    slug: "credit-limits-and-accounts-receivable-for-wholesalers",
    tag: "Credit control",
  },
  {
    title: "Delivery routes and a driver app for wholesale distributors",
    dek: "If your run sheet is a printout and driver updates come through a group chat, here's what running delivery routes on the same system as your orders actually looks like.",
    slug: "delivery-routes-and-driver-app-for-wholesalers",
    tag: "Delivery",
  },
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": `${site}/blog/`,
  name: "Cognit Insights",
  description:
    "Insights on running a wholesale or distribution business on one connected ERP — built-in B2B e-commerce, inventory, accounting, supplier rebates and reporting.",
  url: `${site}/blog/`,
  isPartOf: { "@id": `${site}/#website` },
  hasPart: posts.map((p) => ({
    "@type": "Article",
    headline: p.title,
    description: p.dek,
    url: `${site}/blog/${p.slug}/`,
  })),
};
---

<Layout
  title="Insights — ERP, B2B E-commerce & Distribution | Cognit"
  description="Practical insights for NZ and Australian wholesalers, distributors and product businesses — all-in-one ERP, built-in B2B e-commerce, supplier rebates, inventory, accounting and how to run everything on one system."
  path="/blog"
  schema={collectionSchema}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/warehouse-shelves.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-3xl px-5 pt-20 pb-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">Insights</span>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
          Running your business on <span class="text-gradient-bright">one system.</span>
        </h1>
        <p class="mt-4 text-lg text-slate-300">
          Clear, practical thinking for wholesalers, distributors and product
          businesses — on B2B e-commerce, inventory, accounting, supplier rebates
          and what it really takes to run everything as one connected system.
        </p>
      </div>
    </section>

    <!-- POST GRID -->
    <section class="mx-auto max-w-6xl px-5 pb-20 pt-8 sm:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => (
          <a href={`/blog/${p.slug}`} class="card-hairline card-hover group flex flex-col rounded-3xl p-7">
            <span class="chip w-fit bg-cog-sky text-cog-blue-700">{p.tag}</span>
            <h2 class="mt-4 text-lg font-bold leading-snug text-cog-ink">{p.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-cog-slate">{p.dek}</p>
            <span class="mt-5 inline-block text-sm font-semibold text-cog-purple">Read →</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
