---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const includes = [
  {
    icon: "🇳🇿",
    t: "Real people, your timezone",
    b: "When you get in touch you reach a real New Zealand team who understand distribution — not a faceless ticket queue on the other side of the world.",
  },
  {
    icon: "⚡",
    t: "Fast response",
    b: "We know your business doesn't stop, so we don't keep you waiting. Get a quick, helpful answer when something needs sorting.",
  },
  {
    icon: "🎓",
    t: "Help when you need it",
    b: "New staff to train? A question about a module? We're here to help you and your team get the most out of Cognit, day to day.",
  },
  {
    icon: "🔧",
    t: "Ongoing improvements",
    b: "Cognit keeps getting better. We listen to how you use it and keep improving the system, so it grows with your business over time.",
  },
];

const links = [
  { icon: "❓", t: "FAQ", b: "Quick answers to the most common questions about Cognit.", href: "/faq" },
  { icon: "🚀", t: "Getting started", b: "See how setup, data migration, training and go-live work.", href: "/onboarding" },
  { icon: "📅", t: "Book a demo", b: "Talk to our team and see Cognit running on your business.", href: "/contact" },
];

const faqs = [
  {
    q: "How do I get help?",
    a: "Just get in touch with our team by email at contact@zeabyte.co.nz or by phone on +64 22 169 1376. You'll reach real people in New Zealand who know Cognit and understand distribution.",
  },
  {
    q: "Is support included?",
    a: "Yes. Ongoing local support is part of Cognit, with no per-user fees. After go-live our New Zealand team stays with you for questions, day-to-day help and improvements as your business grows.",
  },
  {
    q: "Can you help train new staff?",
    a: "Absolutely. As your team changes, we're here to help bring new staff up to speed on the parts of Cognit they use — in plain language, until they're comfortable.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
---

<Layout
  title="Help & Support — Talk to the Cognit Team in New Zealand | Cognit"
  description="Cognit is backed by a real New Zealand support team. Reach us by email or phone, get fast help in your timezone, and benefit from ongoing improvements. Local support, included. Book a demo."
  path="/support"
  schema={faqSchema}
>
  <Header />

  <main class="bg-cog-stone text-cog-slate">
    <!-- HERO (photographic) -->
    <section class="orbs relative isolate overflow-hidden">
      <img src="/images/hero-port-night.jpg" alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10 bg-cog-ink/82"></div>
      <div class="dotgrid absolute inset-0 -z-10 opacity-40"></div>
      <div class="mx-auto max-w-4xl px-5 pt-20 pb-20 text-center sm:px-8 sm:pt-28 hero-rise">
        <span class="chip mx-auto border border-white/15 text-slate-200">
          <span class="h-2 w-2 rounded-full bg-cog-teal"></span> Help &amp; support
        </span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Real people, <span class="text-gradient-bright">ready to help.</span>
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-300">
          When you run your whole business on one system, you want to know there's
          someone behind it. With Cognit there is — a real New Zealand team, in your
          timezone, ready to pick up the phone.
        </p>
        <div class="mt-9">
          <a href="/contact" class="btn-grad">Book a demo</a>
        </div>
      </div>
    </section>

    <!-- REACH US -->
    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div class="grid items-stretch gap-5 lg:grid-cols-2">
        <a href="mailto:contact@zeabyte.co.nz" class="card-grad card-hover group flex flex-col justify-between rounded-3xl p-8">
          <div>
            <span class="brand-gradient flex h-11 w-11 items-center justify-center rounded-xl text-xl">✉️</span>
            <h2 class="mt-5 text-2xl font-extrabold tracking-tight text-cog-ink">Email us</h2>
            <p class="mt-3 text-cog-slate">Drop us a line any time and we'll get back to you quickly.</p>
          </div>
          <span class="mt-6 text-lg font-bold text-cog-purple">contact@zeabyte.co.nz</span>
        </a>
        <a href="tel:+64221691376" class="card-grad card-hover group flex flex-col justify-between rounded-3xl p-8">
          <div>
            <span class="brand-gradient flex h-11 w-11 items-center justify-center rounded-xl text-xl">📞</span>
            <h2 class="mt-5 text-2xl font-extrabold tracking-tight text-cog-ink">Call us</h2>
            <p class="mt-3 text-cog-slate">Prefer to talk it through? Give our New Zealand team a call.</p>
          </div>
          <span class="mt-6 text-lg font-bold text-cog-purple">+64 22 169 1376</span>
        </a>
      </div>
    </section>

    <!-- WHAT SUPPORT INCLUDES -->
    <section class="mx-auto max-w-6xl px-5 pb-8 sm:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="chip bg-cog-sky text-cog-blue-700">What our support includes</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">
          Looked after, <span class="text-gradient">locally.</span>
        </h2>
        <p class="mt-4 text-lg text-cog-slate">Support that's part of Cognit — not an upsell.</p>
      </div>
      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {includes.map((i) => (
          <div class="card-hairline card-hover rounded-3xl p-6">
            <span class="brand-gradient flex h-10 w-10 items-center justify-center rounded-xl text-lg">{i.icon}</span>
            <h3 class="mt-4 text-lg font-bold text-cog-ink">{i.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-cog-slate">{i.b}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- HELPFUL LINKS -->
    <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
      <div class="mb-10 max-w-2xl">
        <span class="chip bg-cog-lilac text-cog-purple-600">Where to next</span>
        <h2 class="mt-5 text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">Find what you need.</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        {links.map((l) => (
          <a href={l.href} class="card-hairline card-hover group flex flex-col rounded-3xl p-7">
            <span class="brand-gradient flex h-10 w-10 items-center justify-center rounded-xl text-lg">{l.icon}</span>
            <h3 class="mt-4 text-lg font-bold text-cog-ink">{l.t}</h3>
            <p class="mt-2 text-sm leading-relaxed text-cog-slate">{l.b}</p>
            <span class="mt-4 text-sm font-bold text-cog-purple">Go →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-3xl px-5 pb-20 sm:px-8">
      <h2 class="text-center text-3xl font-extrabold tracking-tight text-cog-ink sm:text-4xl">Support questions, answered</h2>
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="card-hairline group rounded-2xl p-6 open:shadow-md">
            <summary class="flex cursor-pointer list-none items-center justify-between text-lg font-bold text-cog-ink">
              {f.q}
              <span class="ml-4 text-cog-purple transition group-open:rotate-45">＋</span>
            </summary>
            <p class="mt-3 leading-relaxed text-cog-slate">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
